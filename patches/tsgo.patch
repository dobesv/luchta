diff --git a/cmd/luchta-tsc-worker/main.go b/cmd/luchta-tsc-worker/main.go
new file mode 100644
index 000000000..f5a88b699
--- /dev/null
+++ b/cmd/luchta-tsc-worker/main.go
@@ -0,0 +1,18 @@
+package main
+
+import (
+	"context"
+	"os"
+	"os/signal"
+	"syscall"
+
+	"github.com/microsoft/typescript-go/internal/luchta"
+)
+
+func main() {
+	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
+	defer stop()
+	if err := luchta.Serve(ctx, os.Stdin, os.Stdout, os.Stderr); err != nil {
+		os.Exit(1)
+	}
+}
